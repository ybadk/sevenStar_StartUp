# Seven Star Startup Application Configuration
# Copy this file to .env and update values as needed

# Streamlit Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_LOGGER_LEVEL=info
STREAMLIT_CLIENT_SHOW_ERROR_DETAILS=true

# Application Settings
APP_AUTO_RELOAD_TIMEOUT=85
MAX_VIDEO_SIZE_MB=500

# Data paths (relative to app directory)
DATA_DIR=data
VIDEO_UPLOAD_DIR=data/video_uploads
VIDEO_REQUEST_DIR=data/video_requests

# Optional: API Keys for future integrations
# GITHUB_API_KEY=
# EMAIL_API_KEY=
